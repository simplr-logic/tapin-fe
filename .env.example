# Copy to .env.local and fill in real values for local dev.

# Required — NextAuth session/JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Optional — mock demo login (see src/config/env.ts). Falls back to
# demo@tapin.app / demo1234 if unset.
DEMO_USER_EMAIL=demo@tapin.app
DEMO_USER_PASSWORD=demo1234
