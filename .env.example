# Copy to .env.local and fill in real values for local dev.

# Required — Klong gateway base URL. next.config.ts rewrites /auth/*, /me/*,
# and /emails/* to this so the gateway's HttpOnly session cookie lands on
# this app's own origin (localhost:3000). Also read server-side (src/lib/gateway.ts)
# for direct fetches from Server Components.
GATEWAY_URL=http://localhost:8080
